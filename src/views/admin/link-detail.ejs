<%- include('../includes/head') %>
  <div class="admin-layout">
    <nav class="sidebar">
      <div class="sidebar-header">
        <h2>SlimLink</h2>
        <span class="badge">Admin</span>
      </div>
      <ul class="sidebar-nav">
        <li><a href="/admin">Dashboard</a></li>
        <li><a href="/admin/links" class="active">Links</a></li>
      </ul>
    </nav>

    <main class="admin-main">
      <header class="admin-header">
        <a href="/admin/links" class="btn btn-sm">&larr; Back</a>
        <h1>Link Details</h1>
      </header>

      <section class="section">
        <div class="link-info">
          <div class="info-row">
            <span class="info-label">Short URL</span>
            <span><a href="<%= baseUrl %>/<%= link.short_code %>" target="_blank" rel="noopener"><code><%= baseUrl %>/<%= link.short_code %></code></a></span>
          </div>
          <div class="info-row">
            <span class="info-label">Original URL</span>
            <span class="url-cell"><%= link.original_url %></span>
          </div>
          <div class="info-row">
            <span class="info-label">Created</span>
            <span><%= fmtDate(link.created_at) %></span>
          </div>
          <div class="info-row">
            <span class="info-label">Total Clicks</span>
            <span><strong><%= link.clicks %></strong></span>
          </div>
        </div>
      </section>

      <section class="section">
        <h2>Click Log</h2>
        <% if (clicks.length === 0) { %>
          <p class="empty-state">No clicks recorded yet.</p>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>IP Address</th>
                  <th>ISP / Provider</th>
                  <th>Browser</th>
                  <th>OS</th>
                  <th>Device</th>
                  <th>Country</th>
                  <th>Referrer</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody>
                <% clicks.forEach(function(c, i) { %>
                  <tr>
                    <td><%= (page - 1) * 50 + i + 1 %></td>
                    <td><code><%= c.ip || '-' %></code></td>
                    <td><%= c.isp || '-' %></td>
                    <td>
                      <% if (c.browser) { %>
                        <span class="badge badge-browser"><%= c.browser %></span>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td>
                      <% if (c.os) { %>
                        <span class="badge badge-os"><%= c.os %></span>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td>
                      <% if (c.device_type) { %>
                        <span class="badge badge-device badge-<%= c.device_type %>"><%= c.device_type.charAt(0).toUpperCase() + c.device_type.slice(1) %></span>
                        <% if (c.device_vendor) { %><span class="device-detail"><%= c.device_vendor %></span><% } %>
                        <% if (c.device_model) { %><span class="device-detail"><%= c.device_model %></span><% } %>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td><%= c.country || '-' %></td>
                    <td class="url-cell" title="<%= c.referrer || '' %>"><%= c.referrer || '-' %></td>
                    <td class="time-cell"><%= fmtDate(c.created_at) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% if (totalPages > 1) { %>
            <div class="pagination">
              <% if (page > 1) { %>
                <a href="?page=<%= page - 1 %>" class="btn btn-sm">&laquo; Prev</a>
              <% } %>
              <span class="page-info">Page <%= page %> of <%= totalPages %></span>
              <% if (page < totalPages) { %>
                <a href="?page=<%= page + 1 %>" class="btn btn-sm">Next &raquo;</a>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </section>
    </main>
  </div>
<%- include('../includes/foot') %>

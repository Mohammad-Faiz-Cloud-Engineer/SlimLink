<%- include('../includes/head') %>
  <div class="admin-layout">
    <nav class="sidebar">
      <div class="sidebar-header">
        <h2>SlimLink</h2>
        <span class="badge">Admin</span>
      </div>
      <ul class="sidebar-nav">
        <li><a href="/admin" class="active">Dashboard</a></li>
        <li><a href="/admin/links">Links</a></li>
      </ul>
    </nav>

    <main class="admin-main">
      <header class="admin-header">
        <h1>Dashboard</h1>
      </header>

      <div class="stats">
        <div class="stat-card">
          <span class="stat-value"><%= totalLinks %></span>
          <span class="stat-label">Total Links</span>
        </div>
        <div class="stat-card">
          <span class="stat-value"><%= totalClicks %></span>
          <span class="stat-label">Total Clicks</span>
        </div>
      </div>

      <% if (recentClicks.length > 0) { %>
        <section class="section">
          <h2>Recent Clicks</h2>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Link</th>
                  <th>IP</th>
                  <th>ISP</th>
                  <th>Browser</th>
                  <th>OS</th>
                  <th>Device</th>
                  <th>Country</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody>
                <% recentClicks.forEach(function(c) { %>
                  <tr>
                    <td><code><%= c.short_code %></code></td>
                    <td><code><%= c.ip || '-' %></code></td>
                    <td><%= c.isp || '-' %></td>
                    <td><span class="badge badge-browser"><%= c.browser || '-' %></span></td>
                    <td><span class="badge badge-os"><%= c.os || '-' %></span></td>
                    <td>
                      <% if (c.device_type) { %>
                        <span class="badge badge-device badge-<%= c.device_type %>"><%= c.device_type.charAt(0).toUpperCase() + c.device_type.slice(1) %></span>
                        <% if (c.device_vendor) { %><span class="device-detail"><%= c.device_vendor %></span><% } %>
                        <% if (c.device_model) { %><span class="device-detail"><%= c.device_model %></span><% } %>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td><%= c.country || '-' %></td>
                    <td class="time-cell"><%= fmtDate(c.created_at) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      <% } %>
    </main>
  </div>
<%- include('../includes/foot') %>
